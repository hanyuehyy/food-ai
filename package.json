    "@dcloudio/uni-cli-shared": "vue3",
    "@dcloudio/vite-plugin-uni": "vue3",
    "jest": "^30.4.2",
    "miniprogram-automator": "^0.12.1",
    "sass": "^1.83.4",
    "typescript": "^5.7.3",
